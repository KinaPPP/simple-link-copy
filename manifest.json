{
  "manifest_version": 3,
  "name": "シンプルリンクコピー",
  "description": "ページタイトルとURLをシンプルにコピー",
  "version": "1.5",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
